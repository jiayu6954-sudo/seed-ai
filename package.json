{
  "name": "@jiayu6954/seed-ai",
  "version": "0.9.1-alpha.6",
  "description": "Production-grade TypeScript CLI AI coding assistant with long-term memory, multi-provider support, and local LLM integration",
  "type": "module",
  "bin": {
    "seed": "dist/index.js",
    "seed-ai": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && node scripts/add-shebang.mjs",
    "dev": "tsx src/index.ts",
    "dev:chat": "tsx src/index.ts chat",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "keywords": [
    "ai",
    "cli",
    "coding-assistant",
    "anthropic",
    "claude",
    "ollama",
    "local-llm",
    "long-term-memory",
    "typescript"
  ],
  "author": "jiayu6954",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jiayu6954-sudo/seed-ai.git"
  },
  "homepage": "https://github.com/jiayu6954-sudo/seed-ai#readme",
  "bugs": {
    "url": "https://github.com/jiayu6954-sudo/seed-ai/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "ansi-escapes": "^7.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "execa": "^9.3.1",
    "fast-glob": "^3.3.3",
    "ink": "^5.1.0",
    "mime-types": "^2.1.35",
    "ora": "^8.1.0",
    "react": "^18.3.1",
    "string-width": "^7.2.0",
    "strip-ansi": "^7.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.5",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
    "vitest": "^2.1.1"
  }
}
