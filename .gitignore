# ── Video files — upload via GitHub Issue drag-and-drop instead ──────────────
# Embed the resulting CDN URL (github.com/user/repo/assets/...) in README.md.
# This keeps the repo lightweight while videos play natively on GitHub.
assets/demo/videos/
*.mp4
*.mov
*.webm

# ── Build output ────────────────────────────────────────────────────────────
dist/
*.js.map

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ── Secrets & credentials — NEVER commit ─────────────────────────────────────
API.txt
.env
.env.*
*.key
*.pem
settings.json

# ── Runtime data (generated at runtime, not part of source) ──────────────────
# Seed AI stores all runtime data under ~/.seed/ or $SEED_DATA_DIR by default.
# If SEED_DATA_DIR is pointed inside the repo, these patterns protect it.
/MEMORY/
*.seed/
debug.log
*.log

# ── Internal project documents (not for public release) ──────────────────────
MEMORY.md
OPERATIONS.md
LEARNINGS.md
DEMO_SCRIPT.md

# ── Claude Code source reference (local study copy, not part of this project) ─
claude-code-main/
claude/
package/

# ── OS & editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ── TypeScript cache ─────────────────────────────────────────────────────────
*.tsbuildinfo
